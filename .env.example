# Oracle DB — AS-IS (schema 추출 / analyze-legacy / impact 분석)
ORACLE_USER=myuser
ORACLE_PASSWORD=changeme
ORACLE_DSN=localhost:1521/ORCL
ORACLE_SCHEMA_OWNER=myuser
ORACLE_INSTANT_CLIENT_DIR=

# Oracle DB — TO-BE (validate-migration Stage B 검증)
# DSN 만 다르면 USER/PASSWORD 비워두고 위 ORACLE_USER/ORACLE_PASSWORD 로 fallback
# instant client lib 은 AS-IS 와 공용 (ORACLE_INSTANT_CLIENT_DIR 재사용)
ORACLE_TOBE_DSN=newhost:1521/NEWDB
ORACLE_TOBE_USER=
ORACLE_TOBE_PASSWORD=

# LLM / 임베딩 API (Ollama, vLLM 등)
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3
EMBEDDING_API_BASE=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=Qwen3-Embedding-8B

# 패턴 발견용 코딩 특화 모델 (discover-patterns 전용)
# 14B 이상 코딩 모델 권장: qwen2.5-coder-14b, deepseek-coder-v2-16b
# 미설정 시 위 LLM_* 값을 그대로 사용
PATTERN_LLM_API_BASE=
PATTERN_LLM_API_KEY=
PATTERN_LLM_MODEL=qwen2.5-coder:14b
